# ── aiwatcher-mcp environment configuration ───────────────────────────────────
# Copy to .env and fill in secrets. Never commit .env.

# --- Server ---
BACKEND_PORT=10946
FRONTEND_PORT=10947
LOG_LEVEL=INFO

# --- Database ---
DB_PATH=data/aiwatcher.db

# --- Feed polling ---
FEED_POLL_INTERVAL_MINUTES=30
MAX_ITEMS_PER_FEED=50

# --- Claude distillation (REQUIRED for scoring + digest) ---
ANTHROPIC_API_KEY=sk-ant-...
DISTILLATION_MODEL=claude-sonnet-4-20250514
DISTILLATION_INTERVAL_HOURS=6

# --- Alert thresholds ---
# Items scored >= this wake Sandra up via TTS at ALERT_HOUR_UTC:ALERT_MINUTE_UTC
ALERT_THRESHOLD=8.5
ALERT_HOUR_UTC=4      # 4 UTC = 5am Vienna (CET) / 6am Vienna (CEST)
ALERT_MINUTE_UTC=55

# --- Speechops integration ---
# REST endpoint of the speechops backend (separate from MCP transport)
SPEECHOPS_HTTP_URL=http://localhost:10895

# --- Robofang integration ---
ROBOFANG_BACKEND_URL=http://localhost:10871
ROBOFANG_ENABLED=true

# --- Email delivery ---
EMAIL_ENABLED=false
EMAIL_RECIPIENTS=sandra@example.com,steve@example.com
EMAIL_SUBJECT_PREFIX=[AIWatcher]
# email-mcp REST base URL (preferred if running)
EMAIL_MCP_URL=http://localhost:10812
# SMTP fallback (used when EMAIL_MCP_URL is empty or unreachable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Calibre-mcp integration ---
CALIBRE_ENABLED=false
CALIBRE_MCP_URL=http://localhost:10720
CALIBRE_LIBRARY=AI News

# --- Gmail / Alpha Signal email ingestion ---
GMAIL_ENABLED=false
GMAIL_MCP_URL=http://localhost:10812
ALPHASIGNAL_SENDER=newsletter@alphasignal.ai

# --- Prefab UI ---
AIWATCHER_PREFAB_APPS=true
